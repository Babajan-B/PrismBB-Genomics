# ─── Gemini API ───────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vcf:vcfpass@localhost:5432/vcfdb

# ─── VEP Mode: "rest" (default, no install) or "local" ───────
VEP_MODE=rest

# ─── bcftools binary path (auto-detected if in PATH) ─────────
BCFTOOLS_PATH=bcftools

# ─── File storage ─────────────────────────────────────────────
UPLOAD_DIR=./data/uploads

# ─── NCBI E-utilities (optional, increases rate limit) ───────
NCBI_API_KEY=

# ─── App settings ─────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
