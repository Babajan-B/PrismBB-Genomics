# ─── Gemini API ───────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vcf:vcfpass@localhost:5432/vcfdb

# ─── App ──────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── File storage ─────────────────────────────────────────────
UPLOAD_DIR=./data/uploads

# ─── NCBI E-utilities (optional, increases rate limit) ────────
NCBI_API_KEY=
